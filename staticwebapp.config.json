{
  "mimeTypes": {
    ".html": "text/html"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/process_tracker.html",
      "*.{css,js,ico,png,jpg,jpeg,gif,svg,woff,woff2}"
    ]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/process_tracker.html",
      "headers": {
        "Content-Type": "text/html"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Content-Type": "text/html"
      }
    }
  ]
}